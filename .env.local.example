# ─── MercadoPago ─────────────────────────────────────────────────────────────
# Obtenelas en: mercadopago.com.ar/developers/panel → tu aplicación → Credenciales
# Usá las de "Prueba" para testear, las de "Producción" cuando el sitio esté listo
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MP_PUBLIC_KEY=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Resend (emails) ──────────────────────────────────────────────────────────
# Obtenela en: resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# El email desde el que le llega la confirmación al comprador
RESEND_FROM_EMAIL=ventas@tudominio.com

# ─── Supabase (base de datos) ─────────────────────────────────────────────────
# Obtenelos en: supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── URL del sitio (para webhooks y redirecciones de MercadoPago) ─────────────
# En desarrollo: http://localhost:3000
# En producción: la URL de Vercel, ej: https://pw-ecommerce.vercel.app
NEXT_PUBLIC_URL=https://tu-sitio.vercel.app
